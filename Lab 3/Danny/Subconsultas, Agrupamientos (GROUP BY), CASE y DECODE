/* ============================================================
   8. ACTUALIZAR INFORMACION DE PRODUCTO
   Tecnica utilizada: CASE
   ============================================================ */
UPDATE Productos
SET precio_venta = precio_venta * 
  CASE categoria
    WHEN 'Madera' THEN 1.05
    WHEN 'Laminado' THEN 1.03
    ELSE 1.02
  END
WHERE codigo_producto = 'PISO001';

