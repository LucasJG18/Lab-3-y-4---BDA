/* ============================================================
   1. CONSULTAR INVENTARIO DISPONIBLE
   Tecnica utilizada: CASE
   ============================================================ */
SELECT p.codigo_producto, p.nombre, i.stock_disponible,
  CASE 
    WHEN i.stock_disponible <= i.stock_minimo THEN 'CRITICO'
    WHEN i.stock_disponible <= i.stock_minimo*2 THEN 'BAJO'
    ELSE 'NORMAL'
  END AS estado_stock
FROM Productos p JOIN Inventario i ON p.codigo_producto = i.codigo_producto
ORDER BY i.stock_disponible;

/* ============================================================
   2. BUSCAR PRODUCTO POR NOMBRE
   Tecnica utilizada: DECODE
   ============================================================ */
SELECT nombre, categoria, marca,
  DECODE(categoria,
    'Madera','Piso de madera natural',
    'Laminado','Piso laminado sintetico',
    'Otro tipo') AS descripcion_categoria
FROM Productos
WHERE nombre LIKE '%roble%';

/* ============================================================
   3. CONSULTAR HISTORIAL DE COMPRAS DE UN CLIENTE
   Tecnica utilizada: Subconsulta + Agrupamiento (GROUP BY)
   ============================================================ */
SELECT v.codigo_cliente, c.nombres_apellidos,
  COUNT(v.numero_factura) AS total_facturas,
  SUM(v.valor_total) AS total_comprado,
  (SELECT MAX(v2.valor_total) FROM Ventas v2 
   WHERE v2.codigo_cliente = v.codigo_cliente) AS factura_mayor
FROM Ventas v JOIN Clientes c ON v.codigo_cliente = c.codigo_cliente
WHERE v.codigo_cliente = 'CLI001'
GROUP BY v.codigo_cliente, c.nombres_apellidos;

/* ============================================================
   4. CONSULTAR VENTAS REALIZADAS EN CIERTA FECHA (POR FORMA DE PAGO)
   Tecnica utilizada: CASE + Agrupamiento (GROUP BY)
   ============================================================ */
SELECT fecha,
  COUNT(*) AS num_ventas,
  SUM(valor_total) AS total_dia,
  SUM(CASE WHEN forma_pago = 'Efectivo' THEN valor_total ELSE 0 END) AS total_efectivo,
  SUM(CASE WHEN forma_pago = 'Tarjeta' THEN valor_total ELSE 0 END) AS total_tarjeta,
  SUM(CASE WHEN forma_pago = 'Transferencia' THEN valor_total ELSE 0 END) AS total_transferencia
FROM Ventas
WHERE fecha = TO_DATE('2026-03-01','YYYY-MM-DD')
GROUP BY fecha;

/* ============================================================
   5. CONSULTAR PRODUCTOS BAJOS EN STOCK SIN ROTACION
   Tecnica utilizada: Subconsulta (NOT EXISTS) + DECODE con SIGN
   ============================================================ */
SELECT p.codigo_producto, p.nombre, i.stock_disponible, i.stock_minimo,
  DECODE(SIGN(i.stock_disponible - i.stock_minimo), 
    -1,'URGENTE', 0,'REABASTECER','OK') AS urgencia
FROM Productos p JOIN Inventario i ON p.codigo_producto = i.codigo_producto
WHERE i.stock_disponible <= i.stock_minimo
AND NOT EXISTS (SELECT 1 FROM Detalle_Ventas dv WHERE dv.codigo_producto = p.codigo_producto);

